{
    "bin": {"SuperCalculator": "jdeploy-bundle/jdeploy.js"},
    "author": "Thillager",
    "description": "Very nice Calculator",
    "main": "index.js",
    "preferGlobal": true,
    "repository": {"url": "https://github.com/Thillager/SuperCalculator"},
    "version": "1.0.0",
    "jdeploy": {
        "fallbackToUniversal": false,
        "generateLegacyBundles": false,
        "publishTargets": [{
            "name": "github: github",
            "type": "GITHUB",
            "url": "https://github.com/Thillager/SuperCalculator"
        }],
        "javaVersion": "25",
        "jar": "build/libs/SuperCalculator-1.0-SNAPSHOT.jar",
        "title": "SuperCalculator",
        "platformBundlesEnabled": false,
        "downloadPage": {"platforms": ["default"]}
    },
    "dependencies": {
        "command-exists-promise": "^2.0.2",
        "node-fetch": "2.6.7",
        "tar": "^4.4.8",
        "yauzl": "^2.10.0",
        "shelljs": "^0.8.4"
    },
    "license": "ISC",
    "name": "SuperCalculator",
    "files": ["jdeploy-bundle"],
    "scripts": {"test": "echo \"Error: no test specified\" && exit 1"}
}